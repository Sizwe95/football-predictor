# Copy this file to .env and fill values before running

# Optional: Football-data.org API key (for Premier League / Champions League fixtures)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Optional: Sanity GROQ configuration (used when GROQ search is enabled)
SANITY_PROJECT_ID=your_sanity_project_id_here
SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token_here
